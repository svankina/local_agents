#!/usr/bin/env python3
"""Local OpenAI-compatible worker shim for m1-replay jobs."""

from __future__ import annotations

import argparse
import json
import os
import pathlib
import subprocess
import sys
import time
import urllib.request
from datetime import datetime, timezone


TOOLS = [
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": "Read a UTF-8 text file under the workspace.",
            "parameters": {
                "type": "object",
                "properties": {"path": {"type": "string"}},
                "required": ["path"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "list_files",
            "description": "List files under a workspace directory.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {"type": "string", "description": "Directory path, default '.'"},
                    "max_entries": {"type": "integer", "description": "Maximum entries to return"},
                },
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "apply_patch",
            "description": "Apply a unified diff patch in the workspace.",
            "parameters": {
                "type": "object",
                "properties": {"patch": {"type": "string"}},
                "required": ["patch"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "run_bash",
            "description": "Run a shell command in the workspace, timeout 300 seconds.",
            "parameters": {
                "type": "object",
                "properties": {"command": {"type": "string"}},
                "required": ["command"],
            },
        },
    },
]


SYSTEM = """You are a coding worker for the CAD kernel M1 replay.
Implement ONLY the assigned job from the pinned plan. Do not inspect historical
implementations or work outside this workspace. Use tools for all file and shell
access. Keep changes focused on the assigned job. Run the assigned gate command.
Stop when the gate is green and summarize what changed."""


def now_iso() -> str:
    return datetime.now(timezone.utc).astimezone().isoformat(timespec="milliseconds")


def resolve_under(root: pathlib.Path, user_path: str) -> pathlib.Path:
    rel = pathlib.Path(user_path or ".")
    if rel.is_absolute():
        raise ValueError("absolute paths are not allowed")
    path = (root / rel).resolve()
    root_resolved = root.resolve()
    if path != root_resolved and root_resolved not in path.parents:
        raise ValueError("path escapes workspace")
    return path


def v1_url(base: str, path: str) -> str:
    base = base.rstrip("/")
    if base.endswith("/v1"):
        return base + path
    return base + "/v1" + path


def chat(base_url: str, model: str, messages: list[dict], transcript, tools=None) -> dict:
    payload = {
        "model": model,
        "messages": messages,
        "temperature": 0.2,
        "max_tokens": 4096,
        "tools": tools or TOOLS,
    }
    request_record = {"ts": now_iso(), "type": "request", "payload": payload}
    transcript.write(json.dumps(request_record) + "\n")
    transcript.flush()
    req = urllib.request.Request(
        v1_url(base_url, "/chat/completions"),
        data=json.dumps(payload).encode(),
        headers={"Content-Type": "application/json"},
    )
    t0 = time.monotonic()
    with urllib.request.urlopen(req, timeout=900) as r:
        body = json.loads(r.read())
    elapsed = time.monotonic() - t0
    body["_client_wall_s"] = elapsed
    transcript.write(json.dumps({"ts": now_iso(), "type": "response", "body": body}) + "\n")
    transcript.flush()
    return body


def parse_args_obj(raw: object) -> dict:
    if isinstance(raw, dict):
        return raw
    if not isinstance(raw, str):
        return {}
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {}


def safe_diff_paths(patch_text: str) -> tuple[bool, str]:
    for line in patch_text.splitlines():
        if not (line.startswith("--- ") or line.startswith("+++ ")):
            continue
        path = line[4:].strip().split("\t", 1)[0]
        if path == "/dev/null":
            continue
        if path.startswith(("a/", "b/")):
            path = path[2:]
        if pathlib.PurePosixPath(path).is_absolute() or ".." in pathlib.PurePosixPath(path).parts:
            return False, f"patch path escapes workspace: {path}"
    return True, "ok"


class Worker:
    def __init__(self, workspace: pathlib.Path, out: pathlib.Path) -> None:
        self.workspace = workspace.resolve()
        self.out = out.resolve()
        self.out.mkdir(parents=True, exist_ok=True)
        self.commands_log = (self.out / "commands.log").open("a", encoding="utf-8")

    def close(self) -> None:
        self.commands_log.close()

    def tool(self, name: str, args: dict) -> str:
        try:
            if name == "read_file":
                path = resolve_under(self.workspace, str(args.get("path", "")))
                return path.read_text(errors="replace")[:20000]
            if name == "list_files":
                path = resolve_under(self.workspace, str(args.get("path", ".")))
                max_entries = int(args.get("max_entries") or 300)
                entries = []
                for item in sorted(path.iterdir(), key=lambda p: (not p.is_dir(), p.name))[:max_entries]:
                    rel = item.relative_to(self.workspace)
                    entries.append(str(rel) + ("/" if item.is_dir() else ""))
                return "\n".join(entries)
            if name == "apply_patch":
                patch_text = str(args.get("patch", ""))
                ok, why = safe_diff_paths(patch_text)
                if not ok:
                    return f"ERROR: {why}"
                patch_file = self.out / f"tool-patch-{int(time.time() * 1000)}.diff"
                patch_file.write_text(patch_text, encoding="utf-8")
                cmd = ["git", "apply", "--3way", str(patch_file)]
                r = subprocess.run(cmd, cwd=self.workspace, capture_output=True, text=True, timeout=300)
                if r.returncode != 0:
                    r = subprocess.run(
                        ["patch", "-p1", "-i", str(patch_file)],
                        cwd=self.workspace,
                        capture_output=True,
                        text=True,
                        timeout=300,
                    )
                return (r.stdout + r.stderr)[:20000] or f"(exit {r.returncode})"
            if name == "run_bash":
                command = str(args.get("command", ""))
                self.commands_log.write(f"$ {command}\n")
                self.commands_log.flush()
                env = os.environ.copy()
                env["PWD"] = str(self.workspace)
                r = subprocess.run(
                    command,
                    shell=True,
                    cwd=self.workspace,
                    env=env,
                    capture_output=True,
                    text=True,
                    timeout=300,
                )
                out = r.stdout + r.stderr
                self.commands_log.write(out[-20000:] + f"\n[exit {r.returncode}]\n")
                self.commands_log.flush()
                return (out + f"\n(exit {r.returncode})")[-20000:]
        except Exception as exc:
            return f"ERROR: {exc}"
        return f"ERROR: unknown tool {name}"


def run_gate(workspace: pathlib.Path, command: str, commands_log) -> tuple[int, str, float]:
    commands_log.write(f"$ {command}\n")
    commands_log.flush()
    t0 = time.monotonic()
    r = subprocess.run(command, shell=True, cwd=workspace, capture_output=True, text=True, timeout=300)
    elapsed = time.monotonic() - t0
    out = r.stdout + r.stderr
    commands_log.write(out[-20000:] + f"\n[exit {r.returncode}]\n")
    commands_log.flush()
    return r.returncode, out, elapsed


def git_diff(workspace: pathlib.Path) -> str:
    r = subprocess.run(["git", "diff", "--binary"], cwd=workspace, capture_output=True, text=True)
    if r.returncode == 0:
        return r.stdout
    return ""


def write_tokens(out: pathlib.Path, responses: list[dict]) -> None:
    total_prompt = 0
    total_completion = 0
    requests = []
    for i, body in enumerate(responses, 1):
        usage = body.get("usage") or {}
        prompt = usage.get("prompt_tokens") or 0
        completion = usage.get("completion_tokens") or 0
        total_prompt += prompt
        total_completion += completion
        timings = body.get("timings") or {}
        requests.append(
            {
                "request_index": i,
                "prompt_tokens": prompt,
                "completion_tokens": completion,
                "client_wall_s": body.get("_client_wall_s"),
                "timings": timings or None,
            }
        )
    (out / "tokens.json").write_text(
        json.dumps(
            {
                "prompt_tokens": total_prompt,
                "completion_tokens": total_completion,
                "total_tokens": total_prompt + total_completion,
                "requests": requests,
            },
            indent=2,
        ),
        encoding="utf-8",
    )


def dry_run(args) -> int:
    out = pathlib.Path(args.out).resolve()
    out.mkdir(parents=True, exist_ok=True)
    workspace = pathlib.Path(args.workspace).resolve()
    worker = Worker(workspace, out)
    try:
        job = json.loads(pathlib.Path(args.job).read_text())
        with (out / "transcript.jsonl").open("w", encoding="utf-8") as transcript:
            transcript.write(
                json.dumps(
                    {
                        "ts": now_iso(),
                        "type": "dry_run_response",
                        "body": {
                            "choices": [{"message": {"role": "assistant", "content": "DRY RUN"}}],
                            "usage": {"prompt_tokens": 0, "completion_tokens": 0},
                        },
                    }
                )
                + "\n"
            )
        gate_rc, gate_out, gate_s = run_gate(workspace, str(job.get("gate_command") or "true"), worker.commands_log)
        (out / "worker.patch").write_text(git_diff(workspace), encoding="utf-8")
        (out / "worker.md").write_text(
            f"# Dry run\n\nJob: {job.get('id')} - {job.get('title')}\n\nGate exit: {gate_rc}\nGate seconds: {gate_s:.3f}\n",
            encoding="utf-8",
        )
        write_tokens(out, [])
        return 0 if gate_rc == 0 else gate_rc
    finally:
        worker.close()


def main() -> int:
    ap = argparse.ArgumentParser(description="Run one m1-replay local worker job.")
    ap.add_argument("--base-url", required=True)
    ap.add_argument("--model", required=True)
    ap.add_argument("--workspace", required=True)
    ap.add_argument("--plan", required=True)
    ap.add_argument("--job", required=True)
    ap.add_argument("--out", required=True)
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--max-turns", type=int, default=40)
    args = ap.parse_args()

    workspace = pathlib.Path(args.workspace).resolve()
    out = pathlib.Path(args.out).resolve()
    if args.dry_run:
        return dry_run(args)

    job = json.loads(pathlib.Path(args.job).read_text())
    plan = pathlib.Path(args.plan).read_text(errors="replace")
    worker = Worker(workspace, out)
    responses: list[dict] = []
    gate_rc = 1
    gate_out = ""
    gate_s = 0.0
    try:
        messages = [
            {"role": "system", "content": SYSTEM},
            {
                "role": "user",
                "content": json.dumps(
                    {
                        "job": job,
                        "pinned_plan": plan,
                        "workspace": str(workspace),
                        "instructions": "Begin. Implement only this job, run the gate, and stop when green.",
                    }
                ),
            },
        ]
        with (out / "transcript.jsonl").open("w", encoding="utf-8") as transcript:
            for _turn in range(1, args.max_turns + 1):
                body = chat(args.base_url, args.model, messages, transcript, TOOLS)
                responses.append(body)
                msg = body["choices"][0]["message"]
                messages.append(msg)
                tool_calls = msg.get("tool_calls") or []
                if not tool_calls:
                    break
                for tc in tool_calls:
                    name = tc.get("function", {}).get("name", "")
                    call_args = parse_args_obj(tc.get("function", {}).get("arguments"))
                    result = worker.tool(name, call_args)
                    messages.append(
                        {
                            "role": "tool",
                            "tool_call_id": tc.get("id", "0"),
                            "content": result,
                        }
                    )
        gate_command = str(job.get("gate_command") or "true")
        gate_rc, gate_out, gate_s = run_gate(workspace, gate_command, worker.commands_log)
        (out / "worker.patch").write_text(git_diff(workspace), encoding="utf-8")
        (out / "worker.md").write_text(
            "\n".join(
                [
                    f"# Worker {job.get('id', '')}",
                    "",
                    f"Title: {job.get('title', '')}",
                    f"Gate: `{gate_command}`",
                    f"Gate exit: {gate_rc}",
                    f"Gate seconds: {gate_s:.3f}",
                    "",
                    "## Gate Output Tail",
                    "",
                    "```",
                    gate_out[-4000:],
                    "```",
                ]
            ),
            encoding="utf-8",
        )
        write_tokens(out, responses)
        return 0 if gate_rc == 0 else gate_rc
    finally:
        worker.close()


if __name__ == "__main__":
    raise SystemExit(main())
