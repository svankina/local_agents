xt_body bytes to text, optionally via to_native_str_type conversion; on decoding failure a warning is logged for the given spider and an empty (allow-all) body is returned.\"\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":9964,"cache_read_input_tokens":83609,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9964},"output_tokens":39,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"455c3339-708e-46be-b783-7b0d8d3ce5a3","uuid":"0ce20979-54a6-4394-9239-1f9047f92805","request_id":"req_011CbyPaXxXGCMyvobq4m3gt"}
