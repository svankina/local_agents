1781268280.223	{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012chYXrrZ85c4bxDmCMMDoa","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Verify one scratch-modified fan-out item without model judgment.\"\"\"\n3\t\n4\tfrom __future__ import annotations\n5\t\n6\timport argparse\n7\timport ast\n8\timport pathlib\n9\timport re\n10\timport subprocess\n11\timport sys\n12\tfrom typing import Any\n13\t\n14\tSCRIPT_DIR = pathlib.Path(__file__).resolve().parent\n15\tif str(SCRIPT_DIR) not in sys.path:\n16\t    sys.path.insert(0, str(SCRIPT_DIR))\n17\t\n18\tfrom fanout_common import (  # noqa: E402\n19\t    item_file,\n20\t    params_for,\n21\t    parse_source,\n22\t    qualname_targets,\n23\t    read_json,\n24\t    strip_docstrings,\n25\t    write_json,\n26\t)\n27\t\n28\tPLACEHOLDER_RE = re.compile(r\"\\b(todo|tbd|fixme|placeholder)\\b\", re.IGNORECASE)\n29\t\n30\t\n31\tdef fail(check: str, reason: str) -> dict[str, Any]:\n32\t    return {\"passed\": False, \"failed_check\": check, \"reason\": reason}\n33\t\n34\t\n35\tdef ok() -> dict[str, Any]:\n36\t    return {\"passed\": True, \"failed_check\": None, \"reason\": None}\n37\t\n38\t\n39\tdef compile_check(path: pathlib.Path) -> tuple[bool, str]:\n40\t    result = subprocess.run(\n41\t        [sys.executable, \"-m\", \"py_compile\", str(path)],\n42\t        capture_output=True,\n43\t        text=True,\n44\t    )\n45\t    return result.returncode == 0, (result.stdout + result.stderr).strip()\n46\t\n47\t\n48\tdef word_present(text: str, name: str) -> bool:\n49\t    return re.search(rf\"(?<![A-Za-z0-9_]){re.escape(name)}(?![A-Za-z0-9_])\", text) is not None\n50\t\n51\t\n52\tdef verify(corpus: pathlib.Path, item: dict[str, Any], modified_path: pathlib.Path, insertion_rc: int = 0) -> dict[str, Any]:\n53\t    if insertion_rc != 0:\n54\t        return fail(\"insertion_clean\", f\"insert_docstrings.py exited {insertion_rc}\")\n55\t    passed_compile, compile_output = compile_check(modified_path)\n56\t    if not passed_compile:\n57\t        return fail(\"compiles\", compile_output or \"py_compile failed\")\n58\t\n59\t    pristine_path = item_file(corpus, item)\n60\t    pristine_source = pristine_path.read_text(encoding=\"utf-8\")\n61\t    modified_source = modified_path.read_text(encoding=\"utf-8\")\n62\t    pristine_tree = parse_source(pristine_source, item[\"path\"])\n63\t    modified_tree = parse_source(modified_source, str(modified_path))\n64\t    pristine_targets = qualname_targets(pristine_tree)\n65\t\n66\t    coverage_missing = []\n67\t    pristine_nodes = collect_nodes_multi(pristine_tree)\n68\t    modified_nodes = collect_nodes_multi(modified_tree)\n69\t    for qualname in item[\"targets\"]:\n70\t        pairs = list(zip(pristine_nodes.get(qualname, []), modified_nodes.get(qualname, [])))\n71\t        missing_pairs = [pair for pair in pairs if ast.get_docstring(pair[0], clean=False) is None]\n72\t        if not missing_pairs or any(ast.get_docstring(modified, clean=False) is None for _pristine, modified in missing_pairs):\n73\t            coverage_missing.append(qualname)\n74\t    if coverage_missing:\n75\t        return fail(\"coverage\", \"missing inserted docstrings: \" + \", \".join(coverage_missing))\n76\t\n77\t    stripped_pristine = ast.dump(strip_docstrings(pristine_tree), include_attributes=False)\n78\t    stripped_modified = ast.dump(strip_docstrings(modified_tree), include_attributes=False)\n79\t    if stripped_pristine != stripped_modified:\n80\t        return fail(\"ast_equivalence\", \"AST differs after stripping docstrings\")\n81\t\n82\t    for qualname in item[\"targets\"]:\n83\t        pairs = list(zip(pristine_nodes.get(qualname, []), modified_nodes.get(qualname, [])))\n84\t        for pristine_node, modified_node in pairs:\n85\t            if ast.get_docstring(pristine_node, clean=False) is not None:\n86\t                continue\n87\t            docstring = ast.get_docstring(modified_node, clean=False) or \"\"\n88\t            if len(docstring.strip()) < 20 or PLACEHOLDER_RE.search(docstring):\n89\t                return fail(\"non_placeholder\", f\"{qualname} docstring is too short or placeholder-like\")\n90\t            if isinstance(pristine_node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n91\t                params = params_for(pristine_node)\n92\t                missing = [name for name in params if not word_present(docstring, name)]\n93\t                if missing:\n94\t                    return fail(\"parameter_mention\", f\"{qualname} missing parameter mention(s): {', '.join(missing)}\")\n95\t    return ok()\n96\t\n97\t\n98\tdef collect_nodes(tree: ast.AST) -> dict[str, ast.AST]:\n99\t    nodes: dict[str, ast.AST] = {}\n100\t\n101\t    def walk_body(body: list[ast.stmt], stack: list[str]) -> None:\n102\t        for node in body:\n103\t            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):\n104\t                qualname = \".\".join([*stack, node.name])\n105\t                nodes[qualname] = node\n106\t                walk_body(node.body, [*stack, node.name])\n107\t\n108\t    if isinstance(tree, ast.Module):\n109\t        walk_body(tree.body, [])\n110\t    return nodes\n111\t\n112\t\n113\tdef collect_nodes_multi(tree: ast.AST) -> dict[str, list[ast.AST]]:\n114\t    nodes: dict[str, list[ast.AST]] = {}\n115\t\n116\t    def walk_body(body: list[ast.stmt], stack: list[str]) -> None:\n117\t        for node in body:\n118\t            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):\n119\t                qualname = \".\".join([*stack, node.name])\n120\t                nodes.setdefault(qualname, []).append(node)\n121\t                walk_body(node.body, [*stack, node.name])\n122\t\n123\t    if isinstance(tree, ast.Module):\n124\t        walk_body(tree.body, [])\n125\t    return nodes\n126\t\n127\t\n128\tdef main() -> int:\n129\t    parser = argparse.ArgumentParser(description=\"Verify one fan-out item scratch file.\")\n130\t    parser.add_argument(\"--corpus\", required=True)\n131\t    parser.add_argument(\"--item\", required=True)\n132\t    parser.add_argument(\"--modified\", required=True)\n133\t    parser.add_argument(\"--out\", required=True)\n134\t    parser.add_argument(\"--insertion-rc\", type=int, default=0)\n135\t    args = parser.parse_args()\n136\t\n137\t    item = read_json(pathlib.Path(args.item))\n138\t    result = verify(pathlib.Path(args.corpus), item, pathlib.Path(args.modified), args.insertion_rc)\n139\t    write_json(pathlib.Path(args.out), result)\n140\t    return 0 if result[\"passed\"] else 1\n141\t\n142\t\n143\tif __name__ == \"__main__\":\n144\t    raise SystemExit(main())\n145\t"}]},"parent_tool_use_id":null,"session_id":"455c3339-708e-46be-b783-7b0d8d3ce5a3","uuid":"4c548011-75bc-4b6a-a9b7-5cdff4464a04","timestamp":"2026-06-12T12:44:40.220Z","tool_use_result":{"type":"text","file":{"filePath":"/home/svankina/src/local_agents/scripts/fanout/verify_item.py","content":"#!/usr/bin/env python3\n\"\"\"Verify one scratch-modified fan-out item without model judgment.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport ast\nimport pathlib\nimport re\nimport subprocess\nimport sys\nfrom typing import Any\n\nSCRIPT_DIR = pathlib.Path(__file__).resolve().parent\nif str(SCRIPT_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPT_DIR))\n\nfrom fanout_common import (  # noqa: E402\n    item_file,\n    params_for,\n    parse_source,\n    qualname_targets,\n    read_json,\n    strip_docstrings,\n    write_json,\n)\n\nPLACEHOLDER_RE = re.compile(r\"\\b(todo|tbd|fixme|placeholder)\\b\", re.IGNORECASE)\n\n\ndef fail(check: str, reason: str) -> dict[str, Any]:\n    return {\"passed\": False, \"failed_check\": check, \"reason\": reason}\n\n\ndef ok() -> dict[str, Any]:\n    return {\"passed\": True, \"failed_check\": None, \"reason\": None}\n\n\ndef compile_check(path: pathlib.Path) -> tuple[bool, str]:\n    result = subprocess.run(\n        [sys.executable, \"-m\", \"py_compile\", str(path)],\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0, (result.stdout + result.stderr).strip()\n\n\ndef word_present(text: str, name: str) -> bool:\n    return re.search(rf\"(?<![A-Za-z0-9_]){re.escape(name)}(?![A-Za-z0-9_])\", text) is not None\n\n\ndef verify(corpus: pathlib.Path, item: dict[str, Any], modified_path: pathlib.Path, insertion_rc: int = 0) -> dict[str, Any]:\n    if insertion_rc != 0:\n        return fail(\"insertion_clean\", f\"insert_docstrings.py exited {insertion_rc}\")\n    passed_compile, compile_output = compile_check(modified_path)\n    if not passed_compile:\n        return fail(\"compiles\", compile_output or \"py_compile failed\")\n\n    pristine_path = item_file(corpus, item)\n    pristine_source = pristine_path.read_text(encoding=\"utf-8\")\n    modified_source = modified_path.read_text(encoding=\"utf-8\")\n    pristine_tree = parse_source(pristine_source, item[\"path\"])\n    modified_tree = parse_source(modified_source, str(modified_path))\n    pristine_targets = qualname_targets(pristine_tree)\n\n    coverage_missing = []\n    pristine_nodes = collect_nodes_multi(pristine_tree)\n    modified_nodes = collect_nodes_multi(modified_tree)\n    for qualname in item[\"targets\"]:\n        pairs = list(zip(pristine_nodes.get(qualname, []), modified_nodes.get(qualname, [])))\n        missing_pairs = [pair for pair in pairs if ast.get_docstring(pair[0], clean=False) is None]\n        if not missing_pairs or any(ast.get_docstring(modified, clean=False) is None for _pristine, modified in missing_pairs):\n            coverage_missing.append(qualname)\n    if coverage_missing:\n        return fail(\"coverage\", \"missing inserted docstrings: \" + \", \".join(coverage_missing))\n\n    stripped_pristine = ast.dump(strip_docstrings(pristine_tree), include_attributes=False)\n    stripped_modified = ast.dump(strip_docstrings(modified_tree), include_attributes=False)\n    if stripped_pristine != stripped_modified:\n        return fail(\"ast_equivalence\", \"AST differs after stripping docstrings\")\n\n    for qualname in item[\"targets\"]:\n        pairs = list(zip(pristine_nodes.get(qualname, []), modified_nodes.get(qualname, [])))\n        for pristine_node, modified_node in pairs:\n            if ast.get_docstring(pristine_node, clean=False) is not None:\n                continue\n            docstring = ast.get_docstring(modified_node, clean=False) or \"\"\n            if len(docstring.strip()) < 20 or PLACEHOLDER_RE.search(docstring):\n                return fail(\"non_placeholder\", f\"{qualname} docstring is too short or placeholder-like\")\n            if isinstance(pristine_node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n                params = params_for(pristine_node)\n                missing = [name for name in params if not word_present(docstring, name)]\n                if missing:\n                    return fail(\"parameter_mention\", f\"{qualname} missing parameter mention(s): {', '.join(missing)}\")\n    return ok()\n\n\ndef collect_nodes(tree: ast.AST) -> dict[str, ast.AST]:\n    nodes: dict[str, ast.AST] = {}\n\n    def walk_body(body: list[ast.stmt], stack: list[str]) -> None:\n        for node in body:\n            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):\n                qualname = \".\".join([*stack, node.name])\n                nodes[qualname] = node\n                walk_body(node.body, [*stack, node.name])\n\n    if isinstance(tree, ast.Module):\n        walk_body(tree.body, [])\n    return nodes\n\n\ndef collect_nodes_multi(tree: ast.AST) -> dict[str, list[ast.AST]]:\n    nodes: dict[str, list[ast.AST]] = {}\n\n    def walk_body(body: list[ast.stmt], stack: list[str]) -> None:\n        for node in body:\n            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):\n                qualname = \".\".join([*stack, node.name])\n                nodes.setdefault(qualname, []).append(node)\n                walk_body(node.body, [*stack, node.name])\n\n    if isinstance(tree, ast.Module):\n        walk_body(tree.body, [])\n    return nodes\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Verify one fan-out item scratch file.\")\n    parser.add_argument(\"--corpus\", required=True)\n    parser.add_argument(\"--item\", required=True)\n    parser.add_argument(\"--modified\", required=True)\n    parser.add_argument(\"--out\", required=True)\n    parser.add_argument(\"--insertion-rc\", type=int, default=0)\n    args = parser.parse_args()\n\n    item = read_json(pathlib.Path(args.item))\n    result = verify(pathlib.Path(args.corpus), item, pathlib.Path(args.modified), args.insertion_rc)\n    write_json(pathlib.Path(args.out), result)\n    return 0 if result[\"passed\"] else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":145,"startLine":1,"totalLines":145}}}
