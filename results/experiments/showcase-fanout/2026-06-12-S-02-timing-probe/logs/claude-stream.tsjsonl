1781268280.106	{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JzZnz7PksSDQLjNRpH1tq2","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Insert benchmark docstrings into a scratch copy of one Python file.\"\"\"\n3\t\n4\tfrom __future__ import annotations\n5\t\n6\timport argparse\n7\timport ast\n8\timport json\n9\timport pathlib\n10\timport sys\n11\tfrom typing import Any\n12\t\n13\tSCRIPT_DIR = pathlib.Path(__file__).resolve().parent\n14\tif str(SCRIPT_DIR) not in sys.path:\n15\t    sys.path.insert(0, str(SCRIPT_DIR))\n16\t\n17\tfrom fanout_common import item_file, normalize_docstring_keys, parse_source, qualname_targets, read_json  # noqa: E402\n18\t\n19\t\n20\tdef load_response(path: pathlib.Path) -> dict[str, str]:\n21\t    body = read_json(path)\n22\t    docstrings = body.get(\"docstrings\") if isinstance(body, dict) else None\n23\t    if not isinstance(docstrings, dict):\n24\t        raise ValueError(\"response must contain object key docstrings\")\n25\t    out: dict[str, str] = {}\n26\t    for key, value in docstrings.items():\n27\t        if not isinstance(key, str) or not isinstance(value, str):\n28\t            raise ValueError(\"docstring map keys and values must be strings\")\n29\t        out[key] = value\n30\t    return out\n31\t\n32\t\n33\tdef insert_docstrings(source: str, item: dict[str, Any], docstrings: dict[str, str]) -> str:\n34\t    tree = parse_source(source, item[\"path\"])\n35\t    targets = qualname_targets(tree)\n36\t    wanted = list(item[\"targets\"])\n37\t    unknown = sorted(set(wanted) - set(targets))\n38\t    if unknown:\n39\t        raise ValueError(f\"targets not found without docstrings: {', '.join(unknown)}\")\n40\t    docstrings = normalize_docstring_keys(docstrings, wanted)\n41\t\n42\t    lines = source.splitlines(keepends=True)\n43\t    operations: list[tuple[int, str, str]] = []\n44\t    named_nodes: dict[str, list[ast.AST]] = {}\n45\t    for qualname, node in ast_walk_named(parse_source(source, item[\"path\"])):\n46\t        named_nodes.setdefault(qualname, []).append(node)\n47\t    for qualname in wanted:\n48\t        candidate_nodes = [\n49\t            node\n50\t            for node in named_nodes.get(qualname, [])\n51\t            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef))\n52\t            and ast.get_docstring(node, clean=False) is None\n53\t        ]\n54\t        if not candidate_nodes:\n55\t            raise ValueError(f\"target not found without docstring: {qualname}\")\n56\t        for node in candidate_nodes:\n57\t            add_operation(operations, lines, node, qualname, docstrings[qualname])\n58\t\n59\t    seen_replacements: set[int] = set()\n60\t    for line_index, op, text in sorted(operations, key=lambda row: row[0], reverse=True):\n61\t        if op == \"replace\":\n62\t            if line_index in seen_replacements:\n63\t                raise ValueError(f\"multiple one-line suite replacements on line {line_index + 1}\")\n64\t            seen_replacements.add(line_index)\n65\t            lines[line_index] = text\n66\t        else:\n67\t            lines.insert(line_index, text)\n68\t    return \"\".join(lines)\n69\t\n70\t\n71\tdef add_operation(\n72\t    operations: list[tuple[int, str, str]],\n73\t    lines: list[str],\n74\t    node: ast.FunctionDef | ast.AsyncFunctionDef | ast.ClassDef,\n75\t    qualname: str,\n76\t    docstring: str,\n77\t) -> None:\n78\t    if not node.body:\n79\t        raise ValueError(f\"target has no body: {qualname}\")\n80\t    first_stmt = node.body[0]\n81\t    literal = json.dumps(docstring, ensure_ascii=False)\n82\t    suite_line_index = first_stmt.lineno - 1 if first_stmt.lineno != node.lineno else node.lineno - 1\n83\t    suite_line = lines[suite_line_index]\n84\t    suite_text = suite_line[:-1] if suite_line.endswith(\"\\n\") else suite_line\n85\t    suite_colon_index = suite_text.rfind(\":\", 0, first_stmt.col_offset)\n86\t    suite_prefix = suite_text[: suite_colon_index + 1].strip() if suite_colon_index != -1 else \"\"\n87\t    looks_like_suite_header = suite_prefix.startswith((\"def \", \"async def \", \"class \", \")\"))\n88\t    if first_stmt.lineno == node.lineno or (suite_colon_index != -1 and looks_like_suite_header):\n89\t        line_index = suite_line_index\n90\t        original = lines[line_index]\n91\t        newline = \"\\n\" if original.endswith(\"\\n\") else \"\"\n92\t        stripped_newline = original[:-1] if newline else original\n93\t        colon_index = suite_colon_index\n94\t        if colon_index == -1:\n95\t            raise ValueError(f\"cannot locate one-line suite colon for {qualname}\")\n96\t        block_indent = \" \" * (node.col_offset + 4)\n97\t        body_text = stripped_newline[colon_index + 1 :].strip()\n98\t        if not body_text:\n99\t            raise ValueError(f\"empty one-line suite body for {qualname}\")\n100\t        replacement = (\n101\t            stripped_newline[: colon_index + 1]\n102\t            + \"\\n\"\n103\t            + f\"{block_indent}{literal}\\n\"\n104\t            + f\"{block_indent}{body_text}\"\n105\t            + newline\n106\t        )\n107\t        operations.append((line_index, \"replace\", replacement))\n108\t        return\n109\t\n110\t    if isinstance(node, ast.ClassDef) and isinstance(\n111\t        first_stmt, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)\n112\t    ) and first_stmt.decorator_list:\n113\t        insertion_line = min(decorator.lineno for decorator in first_stmt.decorator_list) - 1\n114\t        indent = \" \" * first_stmt.col_offset\n115\t    else:\n116\t        insertion_line = first_stmt.lineno - 1\n117\t        indent = \" \" * first_stmt.col_offset\n118\t    operations.append((insertion_line, \"insert\", f\"{indent}{literal}\\n\"))\n119\t\n120\t\n121\tdef ast_walk_named(tree):\n122\t    def walk_body(body, stack):\n123\t        for node in body:\n124\t            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):\n125\t                next_stack = [*stack, node.name]\n126\t                yield \".\".join(next_stack), node\n127\t                yield from walk_body(node.body, next_stack)\n128\t\n129\t    yield from walk_body(tree.body, [])\n130\t\n131\t\n132\tdef main() -> int:\n133\t    parser = argparse.ArgumentParser(description=\"Insert docstrings for one fan-out item.\")\n134\t    parser.add_argument(\"--corpus\", required=True)\n135\t    parser.add_argument(\"--item\", required=True)\n136\t    parser.add_argument(\"--response\", required=True)\n137\t    parser.add_argument(\"--out\", required=True)\n138\t    args = parser.parse_args()\n139\t\n140\t    item = read_json(pathlib.Path(args.item))\n141\t    source_path = item_file(pathlib.Path(args.corpus), item)\n142\t    source = source_path.read_text(encoding=\"utf-8\")\n143\t    docstrings = load_response(pathlib.Path(args.response))\n144\t    modified = insert_docstrings(source, item, docstrings)\n145\t    out = pathlib.Path(args.out)\n146\t    out.parent.mkdir(parents=True, exist_ok=True)\n147\t    out.write_text(modified, encoding=\"utf-8\")\n148\t    return 0\n149\t\n150\t\n151\tif __name__ == \"__main__\":\n152\t    raise SystemExit(main())\n153\t"}]},"parent_tool_use_id":null,"session_id":"455c3339-708e-46be-b783-7b0d8d3ce5a3","uuid":"c8dd0c66-99aa-465e-8699-6c6dcf8bf1f1","timestamp":"2026-06-12T12:44:40.021Z","tool_use_result":{"type":"text","file":{"filePath":"/home/svankina/src/local_agents/scripts/fanout/insert_docstrings.py","content":"#!/usr/bin/env python3\n\"\"\"Insert benchmark docstrings into a scratch copy of one Python file.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport ast\nimport json\nimport pathlib\nimport sys\nfrom typing import Any\n\nSCRIPT_DIR = pathlib.Path(__file__).resolve().parent\nif str(SCRIPT_DIR) not in sys.path:\n    sys.path.insert(0, str(SCRIPT_DIR))\n\nfrom fanout_common import item_file, normalize_docstring_keys, parse_source, qualname_targets, read_json  # noqa: E402\n\n\ndef load_response(path: pathlib.Path) -> dict[str, str]:\n    body = read_json(path)\n    docstrings = body.get(\"docstrings\") if isinstance(body, dict) else None\n    if not isinstance(docstrings, dict):\n        raise ValueError(\"response must contain object key docstrings\")\n    out: dict[str, str] = {}\n    for key, value in docstrings.items():\n        if not isinstance(key, str) or not isinstance(value, str):\n            raise ValueError(\"docstring map keys and values must be strings\")\n        out[key] = value\n    return out\n\n\ndef insert_docstrings(source: str, item: dict[str, Any], docstrings: dict[str, str]) -> str:\n    tree = parse_source(source, item[\"path\"])\n    targets = qualname_targets(tree)\n    wanted = list(item[\"targets\"])\n    unknown = sorted(set(wanted) - set(targets))\n    if unknown:\n        raise ValueError(f\"targets not found without docstrings: {', '.join(unknown)}\")\n    docstrings = normalize_docstring_keys(docstrings, wanted)\n\n    lines = source.splitlines(keepends=True)\n    operations: list[tuple[int, str, str]] = []\n    named_nodes: dict[str, list[ast.AST]] = {}\n    for qualname, node in ast_walk_named(parse_source(source, item[\"path\"])):\n        named_nodes.setdefault(qualname, []).append(node)\n    for qualname in wanted:\n        candidate_nodes = [\n            node\n            for node in named_nodes.get(qualname, [])\n            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef))\n            and ast.get_docstring(node, clean=False) is None\n        ]\n        if not candidate_nodes:\n            raise ValueError(f\"target not found without docstring: {qualname}\")\n        for node in candidate_nodes:\n            add_operation(operations, lines, node, qualname, docstrings[qualname])\n\n    seen_replacements: set[int] = set()\n    for line_index, op, text in sorted(operations, key=lambda row: row[0], reverse=True):\n        if op == \"replace\":\n            if line_index in seen_replacements:\n                raise ValueError(f\"multiple one-line suite replacements on line {line_index + 1}\")\n            seen_replacements.add(line_index)\n            lines[line_index] = text\n        else:\n            lines.insert(line_index, text)\n    return \"\".join(lines)\n\n\ndef add_operation(\n    operations: list[tuple[int, str, str]],\n    lines: list[str],\n    node: ast.FunctionDef | ast.AsyncFunctionDef | ast.ClassDef,\n    qualname: str,\n    docstring: str,\n) -> None:\n    if not node.body:\n        raise ValueError(f\"target has no body: {qualname}\")\n    first_stmt = node.body[0]\n    literal = json.dumps(docstring, ensure_ascii=False)\n    suite_line_index = first_stmt.lineno - 1 if first_stmt.lineno != node.lineno else node.lineno - 1\n    suite_line = lines[suite_line_index]\n    suite_text = suite_line[:-1] if suite_line.endswith(\"\\n\") else suite_line\n    suite_colon_index = suite_text.rfind(\":\", 0, first_stmt.col_offset)\n    suite_prefix = suite_text[: suite_colon_index + 1].strip() if suite_colon_index != -1 else \"\"\n    looks_like_suite_header = suite_prefix.startswith((\"def \", \"async def \", \"class \", \")\"))\n    if first_stmt.lineno == node.lineno or (suite_colon_index != -1 and looks_like_suite_header):\n        line_index = suite_line_index\n        original = lines[line_index]\n        newline = \"\\n\" if original.endswith(\"\\n\") else \"\"\n        stripped_newline = original[:-1] if newline else original\n        colon_index = suite_colon_index\n        if colon_index == -1:\n            raise ValueError(f\"cannot locate one-line suite colon for {qualname}\")\n        block_indent = \" \" * (node.col_offset + 4)\n        body_text = stripped_newline[colon_index + 1 :].strip()\n        if not body_text:\n            raise ValueError(f\"empty one-line suite body for {qualname}\")\n        replacement = (\n            stripped_newline[: colon_index + 1]\n            + \"\\n\"\n            + f\"{block_indent}{literal}\\n\"\n            + f\"{block_indent}{body_text}\"\n            + newline\n        )\n        operations.append((line_index, \"replace\", replacement))\n        return\n\n    if isinstance(node, ast.ClassDef) and isinstance(\n        first_stmt, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)\n    ) and first_stmt.decorator_list:\n        insertion_line = min(decorator.lineno for decorator in first_stmt.decorator_list) - 1\n        indent = \" \" * first_stmt.col_offset\n    else:\n        insertion_line = first_stmt.lineno - 1\n        indent = \" \" * first_stmt.col_offset\n    operations.append((insertion_line, \"insert\", f\"{indent}{literal}\\n\"))\n\n\ndef ast_walk_named(tree):\n    def walk_body(body, stack):\n        for node in body:\n            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef, ast.ClassDef)):\n                next_stack = [*stack, node.name]\n                yield \".\".join(next_stack), node\n                yield from walk_body(node.body, next_stack)\n\n    yield from walk_body(tree.body, [])\n\n\ndef main() -> int:\n    parser = argparse.ArgumentParser(description=\"Insert docstrings for one fan-out item.\")\n    parser.add_argument(\"--corpus\", required=True)\n    parser.add_argument(\"--item\", required=True)\n    parser.add_argument(\"--response\", required=True)\n    parser.add_argument(\"--out\", required=True)\n    args = parser.parse_args()\n\n    item = read_json(pathlib.Path(args.item))\n    source_path = item_file(pathlib.Path(args.corpus), item)\n    source = source_path.read_text(encoding=\"utf-8\")\n    docstrings = load_response(pathlib.Path(args.response))\n    modified = insert_docstrings(source, item, docstrings)\n    out = pathlib.Path(args.out)\n    out.parent.mkdir(parents=True, exist_ok=True)\n    out.write_text(modified, encoding=\"utf-8\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":153,"startLine":1,"totalLines":153}}}
