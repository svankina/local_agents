1781268345.395	{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LMahRPbSBdQjEtofcPq1Gn","type":"tool_result","content":"1\tfrom __future__ import annotations\n2\t\n3\tfrom typing import TYPE_CHECKING, Any\n4\t\n5\tfrom twisted.internet import defer\n6\tfrom twisted.internet.base import ReactorBase, ThreadedResolver\n7\tfrom twisted.internet.interfaces import (\n8\t    IAddress,\n9\t    IHostnameResolver,\n10\t    IHostResolution,\n11\t    IResolutionReceiver,\n12\t    IResolverSimple,\n13\t)\n14\tfrom zope.interface.declarations import implementer, provider\n15\t\n16\tfrom scrapy.utils.datatypes import LocalCache\n17\t\n18\tif TYPE_CHECKING:\n19\t    from collections.abc import Sequence\n20\t\n21\t    from twisted.internet.defer import Deferred\n22\t\n23\t    # typing.Self requires Python 3.11\n24\t    from typing_extensions import Self\n25\t\n26\t    from scrapy.crawler import Crawler\n27\t\n28\t# TODO: cache misses\n29\tdnscache: LocalCache[str, Any] = LocalCache(10000)\n30\t\n31\t\n32\t@implementer(IResolverSimple)\n33\tclass CachingThreadedResolver(ThreadedResolver):\n34\t    \"\"\"\n35\t    Default caching resolver. IPv4 only, supports setting a timeout value for DNS requests.\n36\t    \"\"\"\n37\t\n38\t    def __init__(self, reactor: ReactorBase, cache_size: int, timeout: float):\n39\t        super().__init__(reactor)\n40\t        dnscache.limit = cache_size\n41\t        self.timeout = timeout\n42\t\n43\t    @classmethod\n44\t    def from_crawler(cls, crawler: Crawler, reactor: ReactorBase) -> Self:\n45\t        if crawler.settings.getbool(\"DNSCACHE_ENABLED\"):\n46\t            cache_size = crawler.settings.getint(\"DNSCACHE_SIZE\")\n47\t        else:\n48\t            cache_size = 0\n49\t        return cls(reactor, cache_size, crawler.settings.getfloat(\"DNS_TIMEOUT\"))\n50\t\n51\t    def install_on_reactor(self) -> None:\n52\t        self.reactor.installResolver(self)\n53\t\n54\t    def getHostByName(self, name: str, timeout: Sequence[int] = ()) -> Deferred[str]:\n55\t        if name in dnscache:\n56\t            return defer.succeed(dnscache[name])\n57\t        # in Twisted<=16.6, getHostByName() is always called with\n58\t        # a default timeout of 60s (actually passed as (1, 3, 11, 45) tuple),\n59\t        # so the input argument above is simply overridden\n60\t        # to enforce Scrapy's DNS_TIMEOUT setting's value\n61\t        # The timeout arg is typed as Sequence[int] but supports floats.\n62\t        timeout = (self.timeout,)  # type: ignore[assignment]\n63\t        d = super().getHostByName(name, timeout)\n64\t        if dnscache.limit:\n65\t            d.addCallback(self._cache_result, name)\n66\t        return d\n67\t\n68\t    def _cache_result(self, result: Any, name: str) -> Any:\n69\t        dnscache[name] = result\n70\t        return result\n71\t\n72\t\n73\t@implementer(IHostResolution)\n74\tclass HostResolution:\n75\t    def __init__(self, name: str):\n76\t        self.name: str = name\n77\t\n78\t    def cancel(self) -> None:\n79\t        raise NotImplementedError\n80\t\n81\t\n82\t@provider(IResolutionReceiver)\n83\tclass _CachingResolutionReceiver:\n84\t    def __init__(self, resolutionReceiver: IResolutionReceiver, hostName: str):\n85\t        self.resolutionReceiver: IResolutionReceiver = resolutionReceiver\n86\t        self.hostName: str = hostName\n87\t        self.addresses: list[IAddress] = []\n88\t\n89\t    def resolutionBegan(self, resolution: IHostResolution) -> None:\n90\t        self.resolutionReceiver.resolutionBegan(resolution)\n91\t        self.resolution = resolution\n92\t\n93\t    def addressResolved(self, address: IAddress) -> None:\n94\t        self.resolutionReceiver.addressResolved(address)\n95\t        self.addresses.append(address)\n96\t\n97\t    def resolutionComplete(self) -> None:\n98\t        self.resolutionReceiver.resolutionComplete()\n99\t        if self.addresses:\n100\t            dnscache[self.hostName] = self.addresses\n101\t\n102\t\n103\t@implementer(IHostnameResolver)\n104\tclass CachingHostnameResolver:\n105\t    \"\"\"\n106\t    Experimental caching resolver. Resolves IPv4 and IPv6 addresses,\n107\t    does not support setting a timeout value for DNS requests.\n108\t    \"\"\"\n109\t\n110\t    def __init__(self, reactor: ReactorBase, cache_size: int):\n111\t        self.reactor: ReactorBase = reactor\n112\t        self.original_resolver: IHostnameResolver = reactor.nameResolver\n113\t        dnscache.limit = cache_size\n114\t\n115\t    @classmethod\n116\t    def from_crawler(cls, crawler: Crawler, reactor: ReactorBase) -> Self:\n117\t        if crawler.settings.getbool(\"DNSCACHE_ENABLED\"):\n118\t            cache_size = crawler.settings.getint(\"DNSCACHE_SIZE\")\n119\t        else:\n120\t            cache_size = 0\n121\t        return cls(reactor, cache_size)\n122\t\n123\t    def install_on_reactor(self) -> None:\n124\t        self.reactor.installNameResolver(self)\n125\t\n126\t    def resolveHostName(\n127\t        self,\n128\t        resolutionReceiver: IResolutionReceiver,\n129\t        hostName: str,\n130\t        portNumber: int = 0,\n131\t        addressTypes: Sequence[type[IAddress]] | None = None,\n132\t        transportSemantics: str = \"TCP\",\n133\t    ) -> IHostResolution:\n134\t        try:\n135\t            addresses = dnscache[hostName]\n136\t        except KeyError:\n137\t            return self.original_resolver.resolveHostName(\n138\t                _CachingResolutionReceiver(resolutionReceiver, hostName),\n139\t                hostName,\n140\t                portNumber,\n141\t                addressTypes,\n142\t                transportSemantics,\n143\t            )\n144\t        resolutionReceiver.resolutionBegan(HostResolution(hostName))\n145\t        for addr in addresses:\n146\t            resolutionReceiver.addressResolved(addr)\n147\t        resolutionReceiver.resolutionComplete()\n148\t        return resolutionReceiver\n149\t"}]},"parent_tool_use_id":null,"session_id":"455c3339-708e-46be-b783-7b0d8d3ce5a3","uuid":"2aff22ab-8809-447f-a5ac-a6679fd4b6d4","timestamp":"2026-06-12T12:45:45.391Z","tool_use_result":{"type":"text","file":{"filePath":"/home/svankina/src/local_agents/.worktrees/showcase/2026-06-12-S-02-timing-probe/scrapy/scrapy/resolver.py","content":"from __future__ import annotations\n\nfrom typing import TYPE_CHECKING, Any\n\nfrom twisted.internet import defer\nfrom twisted.internet.base import ReactorBase, ThreadedResolver\nfrom twisted.internet.interfaces import (\n    IAddress,\n    IHostnameResolver,\n    IHostResolution,\n    IResolutionReceiver,\n    IResolverSimple,\n)\nfrom zope.interface.declarations import implementer, provider\n\nfrom scrapy.utils.datatypes import LocalCache\n\nif TYPE_CHECKING:\n    from collections.abc import Sequence\n\n    from twisted.internet.defer import Deferred\n\n    # typing.Self requires Python 3.11\n    from typing_extensions import Self\n\n    from scrapy.crawler import Crawler\n\n# TODO: cache misses\ndnscache: LocalCache[str, Any] = LocalCache(10000)\n\n\n@implementer(IResolverSimple)\nclass CachingThreadedResolver(ThreadedResolver):\n    \"\"\"\n    Default caching resolver. IPv4 only, supports setting a timeout value for DNS requests.\n    \"\"\"\n\n    def __init__(self, reactor: ReactorBase, cache_size: int, timeout: float):\n        super().__init__(reactor)\n        dnscache.limit = cache_size\n        self.timeout = timeout\n\n    @classmethod\n    def from_crawler(cls, crawler: Crawler, reactor: ReactorBase) -> Self:\n        if crawler.settings.getbool(\"DNSCACHE_ENABLED\"):\n            cache_size = crawler.settings.getint(\"DNSCACHE_SIZE\")\n        else:\n            cache_size = 0\n        return cls(reactor, cache_size, crawler.settings.getfloat(\"DNS_TIMEOUT\"))\n\n    def install_on_reactor(self) -> None:\n        self.reactor.installResolver(self)\n\n    def getHostByName(self, name: str, timeout: Sequence[int] = ()) -> Deferred[str]:\n        if name in dnscache:\n            return defer.succeed(dnscache[name])\n        # in Twisted<=16.6, getHostByName() is always called with\n        # a default timeout of 60s (actually passed as (1, 3, 11, 45) tuple),\n        # so the input argument above is simply overridden\n        # to enforce Scrapy's DNS_TIMEOUT setting's value\n        # The timeout arg is typed as Sequence[int] but supports floats.\n        timeout = (self.timeout,)  # type: ignore[assignment]\n        d = super().getHostByName(name, timeout)\n        if dnscache.limit:\n            d.addCallback(self._cache_result, name)\n        return d\n\n    def _cache_result(self, result: Any, name: str) -> Any:\n        dnscache[name] = result\n        return result\n\n\n@implementer(IHostResolution)\nclass HostResolution:\n    def __init__(self, name: str):\n        self.name: str = name\n\n    def cancel(self) -> None:\n        raise NotImplementedError\n\n\n@provider(IResolutionReceiver)\nclass _CachingResolutionReceiver:\n    def __init__(self, resolutionReceiver: IResolutionReceiver, hostName: str):\n        self.resolutionReceiver: IResolutionReceiver = resolutionReceiver\n        self.hostName: str = hostName\n        self.addresses: list[IAddress] = []\n\n    def resolutionBegan(self, resolution: IHostResolution) -> None:\n        self.resolutionReceiver.resolutionBegan(resolution)\n        self.resolution = resolution\n\n    def addressResolved(self, address: IAddress) -> None:\n        self.resolutionReceiver.addressResolved(address)\n        self.addresses.append(address)\n\n    def resolutionComplete(self) -> None:\n        self.resolutionReceiver.resolutionComplete()\n        if self.addresses:\n            dnscache[self.hostName] = self.addresses\n\n\n@implementer(IHostnameResolver)\nclass CachingHostnameResolver:\n    \"\"\"\n    Experimental caching resolver. Resolves IPv4 and IPv6 addresses,\n    does not support setting a timeout value for DNS requests.\n    \"\"\"\n\n    def __init__(self, reactor: ReactorBase, cache_size: int):\n        self.reactor: ReactorBase = reactor\n        self.original_resolver: IHostnameResolver = reactor.nameResolver\n        dnscache.limit = cache_size\n\n    @classmethod\n    def from_crawler(cls, crawler: Crawler, reactor: ReactorBase) -> Self:\n        if crawler.settings.getbool(\"DNSCACHE_ENABLED\"):\n            cache_size = crawler.settings.getint(\"DNSCACHE_SIZE\")\n        else:\n            cache_size = 0\n        return cls(reactor, cache_size)\n\n    def install_on_reactor(self) -> None:\n        self.reactor.installNameResolver(self)\n\n    def resolveHostName(\n        self,\n        resolutionReceiver: IResolutionReceiver,\n        hostName: str,\n        portNumber: int = 0,\n        addressTypes: Sequence[type[IAddress]] | None = None,\n        transportSemantics: str = \"TCP\",\n    ) -> IHostResolution:\n        try:\n            addresses = dnscache[hostName]\n        except KeyError:\n            return self.original_resolver.resolveHostName(\n                _CachingResolutionReceiver(resolutionReceiver, hostName),\n                hostName,\n                portNumber,\n                addressTypes,\n                transportSemantics,\n            )\n        resolutionReceiver.resolutionBegan(HostResolution(hostName))\n        for addr in addresses:\n            resolutionReceiver.addressResolved(addr)\n        resolutionReceiver.resolutionComplete()\n        return resolutionReceiver\n","numLines":149,"startLine":1,"totalLines":149}}}
